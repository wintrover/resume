  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.5",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/svelte": "^5.2.8",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.2.0",
    "jsdom": "^26.1.0",
    "svelte": "^4.2.19",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "svelte-i18n": "^4.0.0"
  }
