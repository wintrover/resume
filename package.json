{
	"name": "wintrover-portfolio",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"description": "윤수혁의 개인 포트폴리오 웹사이트 - Svelte로 구축",
	"author": "윤수혁 <wintrover@gmail.com>",
	"homepage": "https://wintrover.github.io",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"biome:ci": "biome ci",
		"biome:format": "biome format --write .",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./.svelte-kit/tsconfig.json",
		"knip": "knip",
		"depcruise": "depcruise --config ./.dependency-cruiser.json src",
		"check": "prek run --all-files --stage manual",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./.svelte-kit/tsconfig.json --watch"
	},
	"knip": {
		"$schema": "https://unpkg.com/knip@5/schema.json",
		"project": [
			"src/**/*.{js,svelte}"
		],
		"treatConfigHintsAsErrors": true
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@j178/prek": "^0.3.4",
		"@sveltejs/adapter-static": "^3.0.5",
		"@sveltejs/kit": "^2.8.0",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@testing-library/jest-dom": "^6.9.0",
		"@testing-library/svelte": "^5.2.8",
		"@types/node": "^25.3.3",
		"@vitest/coverage-v8": "^3.2.4",
		"dependency-cruiser": "^17.3.8",
		"fast-check": "^4.2.0",
		"jsdom": "^26.1.0",
		"knip": "^5.85.0",
		"svelte": "^4.2.19",
		"svelte-check": "^4.0.0",
		"typescript": "^5.6.0",
		"vite": "^5.4.0",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"svelte-i18n": "^4.0.0"
	}
}
