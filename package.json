{
  "name": "wintrover-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "윤수혁의 개인 포트폴리오 웹사이트 - Svelte로 구축",
  "author": "윤수혁 <wintrover@gmail.com>",
  "homepage": "https://wintrover.github.io",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "svelte-kit sync && svelte-check --tsconfig ./.svelte-kit/tsconfig.json",
